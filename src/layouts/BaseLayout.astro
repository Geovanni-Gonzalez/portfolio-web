---
import { getLangFromUrl } from "../i18n/utils";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";
import LoadingIndicator from "astro-loading-indicator/component";
import Navbar from "../components/Navbar.astro";
import WarpBackground from "../components/WarpBackground";
import SpotlightEffect from "../components/SpotlightEffect.astro";
import ProgressBar from "../components/ProgressBar.astro";
import ScrollToTop from "../components/ScrollToTop.jsx";
import CommandPalette from "../components/CommandPalette.tsx";

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const defaultTitle =
  lang === "es"
    ? "Geovanni González | Portfolio de Ingeniería en Computación"
    : "Geovanni González | Computer Engineering Portfolio";
const defaultDescription =
  lang === "es"
    ? "Portfolio de Geovanni González, estudiante de Ingeniería en Computación del Tecnológico de Costa Rica enfocado en desarrollo de software, sistemas, estructuras de datos y soluciones web."
    : "Portfolio of Geovanni González, Computer Engineering student at Tecnológico de Costa Rica focused on software engineering, systems, data structures, and practical web solutions.";
const pageTitle = title || defaultTitle;
const pageDescription = description || defaultDescription;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0B1020" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL("/images/profile.webp", Astro.url)} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    <meta property="twitter:image" content={new URL("/images/profile.webp", Astro.url)} />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "dateCreated": "2024-01-01T00:00:00-06:00",
        "dateModified": "2026-05-21T00:00:00-06:00",
        "mainEntity": {
          "@type": "Person",
          "name": "Geovanni González",
          "alternateName": "Geovanni Gonzalez",
          "description": "Estudiante de Ingeniería en Computación en el Tecnológico de Costa Rica, enfocado en desarrollo de software, sistemas y soluciones web.",
          "image": "https://geovanni-portfolio.vercel.app/images/profile.webp",
          "sameAs": [
            "https://github.com/Geovanni-Gonzalez",
            "https://www.linkedin.com/in/geovanni-gonzález-aguilar"
          ]
        }
      }
    </script>

    <Font cssVariable="--font-geist" preload />
    <ClientRouter />
    <LoadingIndicator color="#F97316" height="2px" />
  </head>

  <body class="font-sans min-h-screen text-[var(--text-primary)] transition-colors duration-300">
    <a href="#main-content" class="skip-link">
      {lang === "es" ? "Saltar al contenido principal" : "Skip to main content"}
    </a>
    <div class="fixed inset-0 -z-20 bg-[var(--background)] transition-colors duration-300"></div>
    <ProgressBar />
    <SpotlightEffect />
    <ScrollToTop client:load />
    <CommandPalette client:load lang={lang} />
    <div class="warp-bg-wrapper fixed inset-0 -z-10 pointer-events-none">
      <WarpBackground
        darkColors={["#f97316", "#2dd4bf", "#38bdf8"]}
        lightColors={["#c2410c", "#0f766e", "#0369a1"]}
        speed={0.5}
        swirl={0.65}
        swirlIterations={8}
        shapeScale={0.3}
        client:load
        style={{
          position: "absolute",
          top: 0,
          left: 0,
          width: "100%",
          height: "100%",
          pointerEvents: "none",
        }}
      />
    </div>
    <Navbar lang={lang} />

    <main id="main-content" tabindex="-1" aria-label={lang === "es" ? "Contenido principal" : "Main content"}>
      <slot />
    </main>

    <SpeedInsights />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .warp-bg-wrapper {
    opacity: 0.34;
    filter: saturate(0.85) contrast(0.95);
    transition:
      opacity 0.5s ease,
      filter 0.5s ease;
  }

  :global([data-theme="dark"]) .warp-bg-wrapper {
    opacity: 0.32;
    filter: saturate(0.8) contrast(0.95);
  }

  :global([data-theme="light"]) .warp-bg-wrapper {
    opacity: 0.46;
    filter: saturate(0.95) contrast(0.9) brightness(1.04);
  }
</style>
