---
import { Icon } from "astro-iconify";

interface Props {
  date: string;
  title: string;
  subtitle: string;
  description?: string;
  icon?: string;
  link?: string;
  linkText?: string;
  isLast?: boolean;
}

const {
  date,
  title,
  subtitle,
  description,
  icon = "mdi:school",
  link,
  linkText,
  isLast = false,
} = Astro.props;
---

<div class="relative flex gap-8 pb-16 group" data-aos="fade-up" data-aos-duration="1000">
  <!-- Línea conectora -->
  {
    !isLast && (
      <div class="absolute left-[27px] top-12 bottom-0 w-px bg-gradient-to-b from-[var(--primary)] via-[var(--primary-soft)] to-transparent group-hover:from-[var(--secondary)] transition-all duration-700" />
    )
  }

  <!-- Icono / Punto -->
  <div class="relative flex-shrink-0">
    <div
      class="w-14 h-14 rounded-2xl bg-[var(--card-bg)] backdrop-blur-xl border border-[var(--card-border)] shadow-2xl flex items-center justify-center group-hover:scale-110 group-hover:border-[var(--primary)] transition-all duration-500 z-10"
    >
      <Icon
        name={icon}
        class="w-7 h-7 text-[var(--primary)] group-hover:text-[var(--secondary)] transition-colors duration-500"
      />
    </div>
  </div>

  <!-- Contenido -->
  <div class="flex-grow pt-2">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
      <h3
        class="text-2xl font-black tracking-tighter text-[var(--text-primary)] group-hover:text-[var(--primary)] transition-colors duration-500"
      >
        {title}
      </h3>
      <span
        class="badge-primary text-[10px] uppercase font-black tracking-[0.2em] px-4 py-1.5 rounded-lg border w-fit backdrop-blur-sm"
      >
        {date}
      </span>
    </div>

    <p
      class="text-lg font-bold tracking-tight mb-4 border-l-2 border-[var(--primary)] pl-4 text-[var(--text-primary)]"
    >
      {subtitle}
    </p>

    {
      description && (
        <p class="text-[var(--text-secondary)] leading-relaxed text-sm sm:text-base max-w-3xl font-medium">
          {description}
        </p>
      )
    }

    {
      link && (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary group/link relative inline-flex items-center gap-3 mt-8 px-6 py-2.5 rounded-xl text-sm font-black transition-all duration-500 overflow-hidden hover:text-[var(--button-primary-text)] hover:bg-[var(--primary)]"
        >
          <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/link:translate-x-full transition-transform duration-1000" />
          <Icon
            name="mdi:link-variant"
            class="w-4 h-4 group-hover/link:rotate-45 transition-transform relative z-10"
          />
          <span class="relative z-10">{linkText || "Ver más"}</span>
        </a>
      )
    }
  </div>
</div>

