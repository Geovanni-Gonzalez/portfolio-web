---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import HamburgerMenu from "./HamburgerMenu.jsx";
import LangPicker from "./LangPicker.jsx";
import ThemeToggle from "./ThemeToggle.jsx";
import Logo from "./Logo.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isHome =
  Astro.url.pathname === "/" || Astro.url.pathname === "/en/" || Astro.url.pathname === "/es/";
const homePath = lang === "es" ? "/es/" : "/en/";

const menuItems = [
  { href: isHome ? "#home" : `${homePath}#home`, label: t("nav.home") },
  { href: isHome ? "#about" : `${homePath}#about`, label: t("nav.aboutMe") },
  { href: isHome ? "#skills" : `${homePath}#skills`, label: t("nav.skills") },
  { href: isHome ? "#projects" : `${homePath}#projects`, label: t("nav.projects") },
  { href: `/${lang === "es" ? "" : "en/"}blog`, label: t("nav.blog") },
  { href: isHome ? "#contact" : `${homePath}#contact`, label: t("nav.contact") },
];
---

<nav
  class="fixed left-1/2 top-4 z-50 flex w-[95%] max-w-6xl -translate-x-1/2 items-center justify-between rounded-2xl border border-[var(--color-border)] bg-[var(--color-card-bg)] px-5 py-3 shadow-lg backdrop-blur-xl transition-all duration-500 sm:px-6"
  role="navigation"
  aria-label={lang === "es" ? "Navegación principal" : "Main navigation"}
>
  <a
    href={isHome ? "#home" : `${homePath}#home`}
    class="group rounded-lg transition-transform duration-300 hover:scale-105 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-400"
    aria-label={lang === "es" ? "Ir al inicio" : "Go to home"}
  >
    <Logo class="h-10 w-auto -my-4 relative z-10 logo-custom" />
  </a>

  <ul class="hidden gap-6 text-sm font-semibold text-zinc-600 dark:text-zinc-300 md:flex" role="list">
    {
      menuItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="nav-link relative rounded-md py-1 hover:text-[var(--color-text)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-400 transition-colors duration-300"
            data-target={item.href.includes("#") ? item.href.split("#")[1] : ""}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="md:hidden flex items-center gap-3 relative">
    <ThemeToggle client:load />
    <HamburgerMenu menuItems={menuItems} client:load />
    <LangPicker currentLang={lang} client:load />
  </div>

  <div class="hidden md:flex items-center gap-4">
    <ThemeToggle client:load />
    <LangPicker currentLang={lang} client:load />
  </div>
</nav>

<style>
  .logo-custom {
    color: #f97316;
    transition: color 0.3s ease;
  }

  .group:hover .logo-custom {
    color: white;
  }

  :global(.dark) .logo-custom,
  :global([data-theme="dark"]) .logo-custom {
    color: white;
  }

  :global(.dark) .group:hover .logo-custom,
  :global([data-theme="dark"]) .group:hover .logo-custom {
    color: #f97316;
  }
</style>

<script>
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll(".nav-link");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const currentId = entry.target.getAttribute("id");

        navLinks.forEach((link) => {
          link.classList.remove("text-orange-500", "font-bold");

          if (link.getAttribute("data-target") === currentId) {
            link.classList.add("text-orange-500", "font-bold");
          }
        });
      });
    },
    { threshold: 0.2, rootMargin: "-20% 0px -50% 0px" },
  );

  sections.forEach((section) => observer.observe(section));
</script>
