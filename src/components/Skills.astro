---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-iconify";
import skillsData from "../data/skills.json";
import AOSWrapper from "../components/AOSWrapper.jsx";
import GradientTitle from "./GradientTitle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const skills = skillsData.skills[lang] || skillsData.skills.en;

const levelRank = (level: string) => {
  if (level === "Avanzado" || level === "Advanced") return 3;
  if (level === "Intermedio" || level === "Intermediate") return 2;
  return 1;
};

const levelWidth = (level: string) => `${levelRank(level) * 33}%`;
const subtitle =
  lang === "es"
    ? "Tecnologías organizadas por uso real, con niveles pensados para orientar a reclutadores y colaboradores."
    : "Technologies grouped by real usage, with levels designed to help recruiters and collaborators scan quickly.";
---

<section
  id="skills"
  class="mx-auto max-w-6xl px-4 py-20 text-text sm:px-6 lg:px-8"
  data-aos="fade-up"
  data-aos-duration="1000"
  data-aos-delay="100"
  data-aos-once="true"
>
  <AOSWrapper client:load />

  <GradientTitle title={t("skills.title")} />
  <p class="mx-auto mb-10 max-w-3xl text-center text-base leading-8 text-[var(--color-muted)]">
    {subtitle}
  </p>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
    {
      skills.map((category, index) => (
        <section
          class="spotlight-card group relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-card-bg)] p-6 shadow-2xl backdrop-blur-2xl"
          aria-labelledby={`skill-category-${index}`}
          data-aos="zoom-in-up"
          data-aos-delay={index * 80}
          data-aos-once="true"
        >
          <div class="absolute -right-16 -top-16 h-36 w-36 rounded-full bg-orange-500/8 blur-3xl transition-colors group-hover:bg-orange-500/12" />

          <div class="relative z-10 mb-5">
            <h3 id={`skill-category-${index}`} class="text-xl font-black tracking-tight text-[var(--color-text)]">
              {category.category}
            </h3>
            <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">{category.summary}</p>
          </div>

          <ul class="relative z-10 grid gap-3 sm:grid-cols-2" role="list">
            {category.items.map((skill) => (
              <li class="rounded-xl border border-[var(--color-border)] bg-white/[0.03] p-3 transition hover:border-orange-500/35 hover:bg-orange-500/8">
                <div class="flex items-center gap-3">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-orange-500/10">
                    <Icon name={skill.icon} class="h-6 w-6" aria-hidden="true" />
                  </span>
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-black text-[var(--color-text)]">{skill.name}</p>
                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-orange-500/85">
                      {skill.level}
                    </p>
                  </div>
                </div>
                <div
                  class="mt-3 h-1.5 overflow-hidden rounded-full bg-black/10 dark:bg-white/10"
                  aria-hidden="true"
                >
                  <div
                    class="h-full rounded-full bg-gradient-to-r from-orange-600 to-yellow-400"
                    style={{ width: levelWidth(skill.level) }}
                  />
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</section>
