---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-iconify";
import SocialButtons from "./SocialButtons.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cvFile = lang === "es" ? "/documents/CurriculumEstudiantil.pdf" : "/documents/StudentCurriculum.pdf";

const metrics = [
  { label: t("hero.metricProjects"), value: t("hero.metricProjectsValue") },
  { label: t("hero.metricFocus"), value: t("hero.metricFocusValue") },
  { label: t("hero.metricStack"), value: t("hero.metricStackValue") },
];

const stackSignals = ["Python", "C++", "Java", "TypeScript", "React", "SQL"];
const systemRows =
  lang === "es"
    ? [
        { label: "enfoque", value: "software · sistemas · datos" },
        { label: "estado", value: "abierto a oportunidades" },
        { label: "modo", value: "construir, medir, mejorar" },
      ]
    : [
        { label: "focus", value: "software · systems · data" },
        { label: "status", value: "open to opportunities" },
        { label: "mode", value: "build, measure, improve" },
      ];
---

<section
  id="home"
  class="relative min-h-screen w-full overflow-hidden px-4 pb-12 pt-28 sm:px-8 sm:pt-36"
  aria-labelledby="hero-title"
>
  <div class="mx-auto grid min-h-[calc(100vh-9rem)] max-w-6xl items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="relative z-10" data-aos="fade-up" data-aos-duration="900">
      <p class="badge-secondary mb-5 inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs font-bold uppercase tracking-[0.14em]">
        <Icon name="mdi:school-outline" class="h-4 w-4" aria-hidden="true" />
        {t("hero.kicker")}
      </p>

      <h1
        id="hero-title"
        class="max-w-5xl text-balance text-5xl font-black leading-[0.98] text-[var(--hero-title)] sm:text-6xl lg:text-7xl"
      >
        {t("hero.name")}
        <span class="block text-[var(--primary)]">
          {t("hero.lastname")}
        </span>
      </h1>

      <p class="mt-5 text-xl font-semibold text-[var(--primary)] sm:text-2xl">
        {t("hero.title")}
      </p>
      <p class="mt-6 max-w-3xl text-pretty text-base font-medium leading-8 text-[var(--hero-muted)] sm:text-lg">
        {t("hero.value")}
      </p>
      <p class="mt-4 max-w-2xl text-sm font-medium text-[var(--text-secondary)]">
        {t("hero.available")}
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href="#projects"
          class="btn-primary inline-flex min-h-12 items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--primary)]"
        >
          {t("hero.primaryCta")}
          <Icon name="mdi:arrow-right" class="h-5 w-5" aria-hidden="true" />
        </a>
        <a
          href={cvFile}
          download
          class="btn-secondary inline-flex min-h-12 items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold backdrop-blur transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--secondary)]"
        >
          <Icon name="mdi:file-download-outline" class="h-5 w-5" aria-hidden="true" />
          {t("hero.secondaryCta")}
        </a>
      </div>

      <div class="mt-7">
        <SocialButtons />
      </div>
    </div>

    <aside
      class="spotlight-card tech-panel relative z-10 overflow-hidden rounded-2xl border border-[var(--card-border)] p-5 sm:p-6"
      aria-label={lang === "es" ? "Resumen profesional" : "Professional summary"}
      data-aos="fade-left"
      data-aos-delay="150"
    >
      <div class="tech-panel-grid" aria-hidden="true"></div>
      <div class="absolute -right-10 -top-10 h-36 w-36 rounded-full bg-[var(--secondary-soft)] blur-3xl"></div>

      <div class="relative flex items-center justify-between gap-4 border-b border-[var(--card-border)] pb-4">
        <div>
          <p class="font-mono text-xs font-semibold text-[var(--secondary)]">
            {lang === "es" ? "perfil técnico" : "technical profile"}
          </p>
          <p class="mt-1 text-sm font-bold text-[var(--text-primary)]">Geovanni González</p>
        </div>
        <span class="badge-secondary inline-flex items-center gap-2 rounded-full border px-3 py-1 font-mono text-xs font-semibold">
          <span class="h-2 w-2 rounded-full bg-[var(--secondary)] shadow-[0_0_14px_var(--secondary)]"></span>
          online
        </span>
      </div>

      <div class="relative mt-5 grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
        {
          metrics.map((metric) => (
            <div class="rounded-xl border border-[var(--card-border)] bg-[var(--surface-elevated)] p-4">
              <p class="font-mono text-xs font-semibold text-[var(--secondary)]">
                {metric.label}
              </p>
              <p class="mt-2 text-xl font-black leading-snug text-[var(--text-primary)]">
                {metric.value}
              </p>
            </div>
          ))
        }
      </div>

      <div class="relative mt-5 rounded-xl border border-[var(--card-border)] bg-[var(--surface-elevated)] p-4 font-mono text-xs">
        {
          systemRows.map((row) => (
            <div class="flex items-start justify-between gap-4 py-2">
              <span class="font-semibold text-[var(--text-secondary)]">{row.label}</span>
              <span class="text-right font-semibold text-[var(--text-primary)]">{row.value}</span>
            </div>
          ))
        }
      </div>

      <div class="relative mt-5 flex flex-wrap gap-2">
        {
          stackSignals.map((tech) => (
            <span class="badge-secondary rounded-lg border px-3 py-1.5 font-mono text-xs font-semibold">
              {tech}
            </span>
          ))
        }
      </div>
    </aside>
  </div>

  <a
    href="#about"
    class="absolute bottom-5 left-1/2 z-10 hidden -translate-x-1/2 flex-col items-center gap-2 text-xs font-semibold text-[var(--text-secondary)] transition hover:text-[var(--primary)] sm:flex"
    aria-label={lang === "es" ? "Ir a Sobre mí" : "Go to About"}
  >
    <span>{lang === "es" ? "Explorar" : "Explore"}</span>
    <span class="h-10 w-6 rounded-full border-2 border-current p-1">
      <span class="mx-auto block h-2 w-1 animate-bounce rounded-full bg-current"></span>
    </span>
  </a>
</section>

<style>
  .tech-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 0%, var(--secondary-soft) 42%, transparent 70%);
    transform: translateX(-100%);
    animation: panel-scan 7s ease-in-out infinite;
  }

  .tech-panel-grid {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-image:
      linear-gradient(color-mix(in srgb, var(--secondary) 16%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--secondary) 16%, transparent) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(circle at 50% 40%, black, transparent 75%);
  }

  @keyframes panel-scan {
    0%,
    44% {
      transform: translateX(-100%);
    }
    70%,
    100% {
      transform: translateX(100%);
    }
  }
</style>
