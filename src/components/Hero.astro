---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-iconify";
import SocialButtons from "./SocialButtons.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cvFile = lang === "es" ? "/documents/CurriculumEstudiantil.pdf" : "/documents/StudentCurriculum.pdf";

const metrics = [
  { label: t("hero.metricProjects"), value: t("hero.metricProjectsValue") },
  { label: t("hero.metricFocus"), value: t("hero.metricFocusValue") },
  { label: t("hero.metricStack"), value: t("hero.metricStackValue") },
];
---

<section
  id="home"
  class="relative w-full min-h-screen overflow-hidden px-4 pb-12 pt-28 sm:px-8 sm:pt-36"
  aria-labelledby="hero-title"
>
  <div class="mx-auto grid min-h-[calc(100vh-9rem)] max-w-6xl items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="relative z-10" data-aos="fade-up" data-aos-duration="900">
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-orange-500/25 bg-orange-500/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-orange-300">
        <Icon name="mdi:school-outline" class="h-4 w-4" aria-hidden="true" />
        {t("hero.kicker")}
      </p>

      <h1
        id="hero-title"
        class="max-w-5xl text-balance text-5xl font-black leading-[0.95] text-white sm:text-6xl lg:text-7xl"
      >
        {t("hero.name")}
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-orange-200 via-white to-orange-300 drop-shadow-[0_0_22px_rgba(249,115,22,0.35)]">
          {t("hero.lastname")}
        </span>
      </h1>

      <p class="mt-5 text-xl font-semibold text-orange-200 sm:text-2xl">
        {t("hero.title")}
      </p>
      <p class="mt-6 max-w-3xl text-pretty text-base leading-8 text-white/78 sm:text-lg">
        {t("hero.value")}
      </p>
      <p class="mt-4 max-w-2xl text-sm font-medium text-orange-100/80">
        {t("hero.available")}
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href="#projects"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-orange-600 px-6 py-3 text-sm font-black uppercase tracking-widest text-white shadow-[0_0_24px_rgba(234,88,12,0.32)] transition hover:-translate-y-0.5 hover:bg-orange-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-300"
        >
          {t("hero.primaryCta")}
          <Icon name="mdi:arrow-right" class="h-5 w-5" aria-hidden="true" />
        </a>
        <a
          href={cvFile}
          download
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/8 px-6 py-3 text-sm font-black uppercase tracking-widest text-white backdrop-blur transition hover:-translate-y-0.5 hover:border-orange-300/70 hover:bg-white/12 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-300"
        >
          <Icon name="mdi:file-download-outline" class="h-5 w-5" aria-hidden="true" />
          {t("hero.secondaryCta")}
        </a>
      </div>

      <div class="mt-7">
        <SocialButtons />
      </div>
    </div>

    <aside
      class="relative z-10 rounded-3xl border border-white/10 bg-black/25 p-5 shadow-2xl backdrop-blur-xl sm:p-6"
      aria-label={lang === "es" ? "Resumen profesional" : "Professional summary"}
      data-aos="fade-left"
      data-aos-delay="150"
    >
      <div class="absolute -right-10 -top-10 h-36 w-36 rounded-full bg-orange-500/20 blur-3xl"></div>
      <div class="relative space-y-4">
        {
          metrics.map((metric) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-orange-300/80">
                {metric.label}
              </p>
              <p class="mt-2 text-xl font-black leading-snug text-white">{metric.value}</p>
            </div>
          ))
        }
      </div>
    </aside>
  </div>

  <a
    href="#about"
    class="absolute bottom-5 left-1/2 z-10 hidden -translate-x-1/2 flex-col items-center gap-2 text-[10px] font-black uppercase tracking-[0.3em] text-white/55 transition hover:text-orange-200 sm:flex"
    aria-label={lang === "es" ? "Ir a Sobre mí" : "Go to About"}
  >
    <span>{lang === "es" ? "Explorar" : "Explore"}</span>
    <span class="h-10 w-6 rounded-full border-2 border-current p-1">
      <span class="mx-auto block h-2 w-1 animate-bounce rounded-full bg-current"></span>
    </span>
  </a>
</section>
