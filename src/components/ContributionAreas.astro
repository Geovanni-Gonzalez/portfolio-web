---
import { Icon } from "astro-iconify";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import GradientTitle from "./GradientTitle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const areas = [
  {
    title: t("areas.software.title"),
    description: t("areas.software.description"),
    icon: "mdi:application-brackets-outline",
  },
  {
    title: t("areas.systems.title"),
    description: t("areas.systems.description"),
    icon: "mdi:graph-outline",
  },
  {
    title: t("areas.data.title"),
    description: t("areas.data.description"),
    icon: "mdi:database-search-outline",
  },
  {
    title: t("areas.collab.title"),
    description: t("areas.collab.description"),
    icon: "mdi:account-group-outline",
  },
];
---

<section
  id="areas"
  class="mx-auto max-w-6xl px-4 py-20 sm:px-6"
  data-aos="fade-up"
  data-aos-duration="1000"
>
  <GradientTitle title={t("areas.title")} />
  <p class="mx-auto mb-10 max-w-3xl text-center text-base font-medium leading-8 text-[var(--text-secondary)]">
    {t("areas.subtitle")}
  </p>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      areas.map((area) => (
        <article class="spotlight-card group flex h-full flex-col rounded-2xl border border-[var(--card-border)] bg-[var(--card-bg)] p-6 shadow-2xl backdrop-blur-2xl transition hover:border-[var(--primary)]">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--secondary-soft)] text-[var(--secondary)] transition group-hover:bg-[var(--secondary)] group-hover:text-[var(--button-primary-text)]">
            <Icon name={area.icon} class="h-7 w-7" aria-hidden="true" />
          </div>
          <h3 class="text-lg font-black tracking-tight text-[var(--text-primary)]">{area.title}</h3>
          <p class="mt-3 text-sm font-medium leading-7 text-[var(--text-secondary)]">{area.description}</p>
        </article>
      ))
    }
  </div>
</section>
