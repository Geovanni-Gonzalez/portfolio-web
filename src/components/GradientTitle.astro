---
interface Props {
  title: string;
  className?: string;
  underlineClass?: string;
}

const {
  title,
  className = "text-3xl sm:text-4xl md:text-5xl mb-12",
  underlineClass = "w-16 sm:w-20",
} = Astro.props;
---

<h2
  class:list={[
    "section-heading font-black text-center tracking-tight select-none relative flex flex-col items-center",
    className,
  ]}
>
  <span class="section-accent" aria-hidden="true"></span>
  <span class="section-title-text">{title}</span>
  <span class:list={["section-rule", underlineClass]} aria-hidden="true"></span>
</h2>

<style>
  .section-heading {
    letter-spacing: -0.035em;
  }

  .section-accent {
    width: 0.65rem;
    height: 0.65rem;
    margin-bottom: 0.85rem;
    border-radius: 999px;
    background: var(--primary);
    box-shadow: 0 0 0 6px var(--primary-soft);
  }

  .section-title-text {
    color: var(--text-primary);
  }

  .section-rule {
    display: block;
    height: 3px;
    margin-top: 1rem;
    border-radius: 999px;
    background: var(--primary);
    opacity: 0.9;
  }
</style>
