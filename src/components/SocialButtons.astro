---
import { Icon } from "astro-iconify";

const links = [
  {
    name: "GitHub",
    url: "https://github.com/Geovanni-Gonzalez",
    icon: "mdi:github",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/geovanni-gonzález-aguilar",
    icon: "mdi:linkedin",
  },
];
---

<div class="flex flex-wrap gap-3">
  {
    links.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={link.name}
        class="inline-flex min-h-11 items-center gap-2 rounded-xl border border-[var(--card-border)] bg-[var(--card-bg)] px-4 py-2 text-sm font-bold text-[var(--text-primary)] backdrop-blur transition hover:-translate-y-0.5 hover:border-[var(--secondary)] hover:bg-[var(--secondary-soft)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--secondary)]"
      >
        <Icon name={link.icon} class="h-5 w-5" aria-hidden="true" />
        <span>{link.name}</span>
      </a>
    ))
  }
</div>
